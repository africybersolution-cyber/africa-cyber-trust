'use client';

import { useAuth } from '@/lib/auth-context';
import { useRouter } from 'next/navigation';
import { useState, useEffect } from 'react';

interface Scan {
  id: string;
  assetName: string;
  assetUrl: string;
  status: 'completed' | 'running' | 'failed';
  score: number;
  startedAt: string;
  completedAt: string;
  duration: string;
  vulnerabilities: {
    critical: number;
    high: number;
    medium: number;
    low: number;
  };
  findings: Array<{
    title: string;
    severity: 'critical' | 'high' | 'medium' | 'low';
    description: string;
    solution: string;
  }>;
}

export default function ScansPage() {
  const { user, logout } = useAuth();
  const router = useRouter();
  const [loading, setLoading] = useState(true);
  const [selectedScan, setSelectedScan] = useState<Scan | null>(null);

  const [scans, setScans] = useState<Scan[]>([
    {
      id: '1',
      assetName: 'example.com',
      assetUrl: 'https://example.com',
      status: 'completed',
      score: 95,
      startedAt: '2 hours ago',
      completedAt: '2 hours ago',
      duration: '45 seconds',
      vulnerabilities: { critical: 0, high: 0, medium: 2, low: 5 },
      findings: [
        {
          title: 'Missing X-Frame-Options Header',
          severity: 'medium',
          description: 'The X-Frame-Options HTTP response header is not set, which may allow clickjacking attacks.',
          solution: 'Add X-Frame-Options: DENY or SAMEORIGIN header to all responses.'
        },
        {
          title: 'Outdated jQuery Version',
          severity: 'low',
          description: 'Using jQuery 1.12.4 which has known vulnerabilities.',
          solution: 'Update to the latest version of jQuery (3.6+).'
        }
      ]
    },
    {
      id: '2',
      assetName: 'api.example.com',
      assetUrl: 'https://api.example.com',
      status: 'completed',
      score: 88,
      startedAt: '5 hours ago',
      completedAt: '5 hours ago',
      duration: '1m 12s',
      vulnerabilities: { critical: 0, high: 1, medium: 3, low: 8 },
      findings: [
        {
          title: 'SQL Injection Vulnerability',
          severity: 'high',
          description: 'Potential SQL injection in /api/users endpoint. Input validation is insufficient.',
          solution: 'Use parameterized queries and implement input sanitization.'
        }
      ]
    },
    {
      id: '3',
      assetName: 'app.example.com',
      assetUrl: 'https://app.example.com',
      status: 'running',
      score: 0,
      startedAt: 'Just now',
      completedAt: '-',
      duration: '-',
      vulnerabilities: { critical: 0, high: 0, medium: 0, low: 0 },
      findings: []
    },
  ]);

  useEffect(() => {
    if (!user) {
      router.push('/login');
    } else {
      setLoading(false);
    }
  }, [user, router]);

  if (loading) {
    return (
      <div className="min-h-screen bg-slate-900 flex items-center justify-center">
        <div className="text-white">Loading...</div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900">
      {/* Top Navigation */}
      <nav className="bg-slate-900/90 border-b backdrop-blur-sm sticky top-0 z-50" style={{ borderColor: 'rgba(0, 71, 171, 0.3)' }}>
        <div className="container mx-auto px-4 py-4">
          <div className="flex items-center justify-between">
            <a href="/dashboard" className="flex items-center gap-3">
              <div className="w-10 h-10 rounded-lg flex items-center justify-center" style={{ background: 'linear-gradient(135deg, #0047AB 0%, #DAA520 100%)' }}>
                <svg className="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div className="hidden md:block">
                <div className="text-sm font-bold">
                  <span style={{ color: '#0047AB' }}>AFRICA CYBER </span>
                  <span style={{ color: '#DAA520' }}>TRUST</span>
                </div>
              </div>
            </a>

            <div className="flex items-center gap-4">
              <a href="/dashboard" className="text-gray-400 hover:text-white">← Back to Dashboard</a>
              <button onClick={() => logout()} className="px-4 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-slate-800">
                Sign Out
              </button>
            </div>
          </div>
        </div>
      </nav>

      {/* Main Content */}
      <div className="container mx-auto px-4 py-8">
        <div className="mb-8">
          <h1 className="text-3xl font-bold text-white mb-2">Security Scans</h1>
          <p className="text-gray-400">View detailed scan results and vulnerability reports</p>
        </div>

        {selectedScan ? (
          /* Detailed Scan View */
          <div>
            <button
              onClick={() => setSelectedScan(null)}
              className="mb-6 text-gray-400 hover:text-white flex items-center gap-2"
            >
              ← Back to All Scans
            </button>

            <div className="space-y-6">
              {/* Scan Header */}
              <div className="bg-slate-800/50 backdrop-blur-sm border rounded-2xl p-6" style={{ borderColor: 'rgba(71, 85, 105, 0.5)' }}>
                <div className="flex items-start justify-between mb-4">
                  <div>
                    <h2 className="text-2xl font-bold text-white mb-2">{selectedScan.assetName}</h2>
                    <div className="text-gray-400">{selectedScan.assetUrl}</div>
                  </div>
                  <div className="text-center">
                    <div className="text-4xl font-bold mb-1" style={{
                      color: selectedScan.score >= 90 ? '#10b981' : selectedScan.score >= 70 ? '#f59e0b' : '#ef4444'
                    }}>
                      {selectedScan.score}
                    </div>
                    <div className="text-sm text-gray-400">Security Score</div>
                  </div>
                </div>

                <div className="grid md:grid-cols-4 gap-4">
                  <div className="bg-slate-900/50 rounded-lg p-3">
                    <div className="text-sm text-gray-400 mb-1">Status</div>
                    <div className={`font-medium ${
                      selectedScan.status === 'completed' ? 'text-green-400' :
                      selectedScan.status === 'running' ? 'text-blue-400' : 'text-red-400'
                    }`}>
                      {selectedScan.status.charAt(0).toUpperCase() + selectedScan.status.slice(1)}
                    </div>
                  </div>
                  <div className="bg-slate-900/50 rounded-lg p-3">
                    <div className="text-sm text-gray-400 mb-1">Started</div>
                    <div className="font-medium text-white">{selectedScan.startedAt}</div>
                  </div>
                  <div className="bg-slate-900/50 rounded-lg p-3">
                    <div className="text-sm text-gray-400 mb-1">Duration</div>
                    <div className="font-medium text-white">{selectedScan.duration}</div>
                  </div>
                  <div className="bg-slate-900/50 rounded-lg p-3">
                    <div className="text-sm text-gray-400 mb-1">Total Issues</div>
                    <div className="font-medium text-white">
                      {Object.values(selectedScan.vulnerabilities).reduce((a, b) => a + b, 0)}
                    </div>
                  </div>
                </div>
              </div>

              {/* Vulnerabilities Overview */}
              <div className="bg-slate-800/50 backdrop-blur-sm border rounded-2xl p-6" style={{ borderColor: 'rgba(71, 85, 105, 0.5)' }}>
                <h3 className="text-xl font-bold text-white mb-4">Vulnerabilities by Severity</h3>
                <div className="grid md:grid-cols-4 gap-4">
                  <div className="bg-red-500/10 border border-red-500/30 rounded-lg p-4">
                    <div className="text-3xl font-bold text-red-400 mb-1">{selectedScan.vulnerabilities.critical}</div>
                    <div className="text-sm text-red-300">Critical</div>
                  </div>
                  <div className="bg-orange-500/10 border border-orange-500/30 rounded-lg p-4">
                    <div className="text-3xl font-bold text-orange-400 mb-1">{selectedScan.vulnerabilities.high}</div>
                    <div className="text-sm text-orange-300">High</div>
                  </div>
                  <div className="bg-yellow-500/10 border border-yellow-500/30 rounded-lg p-4">
                    <div className="text-3xl font-bold text-yellow-400 mb-1">{selectedScan.vulnerabilities.medium}</div>
                    <div className="text-sm text-yellow-300">Medium</div>
                  </div>
                  <div className="bg-blue-500/10 border border-blue-500/30 rounded-lg p-4">
                    <div className="text-3xl font-bold text-blue-400 mb-1">{selectedScan.vulnerabilities.low}</div>
                    <div className="text-sm text-blue-300">Low</div>
                  </div>
                </div>
              </div>

              {/* Findings */}
              <div className="bg-slate-800/50 backdrop-blur-sm border rounded-2xl p-6" style={{ borderColor: 'rgba(71, 85, 105, 0.5)' }}>
                <h3 className="text-xl font-bold text-white mb-4">Detailed Findings</h3>
                <div className="space-y-4">
                  {selectedScan.findings.map((finding, idx) => (
                    <div key={idx} className="border rounded-lg p-4" style={{
                      borderColor: finding.severity === 'critical' ? 'rgba(239, 68, 68, 0.5)' :
                                   finding.severity === 'high' ? 'rgba(249, 115, 22, 0.5)' :
                                   finding.severity === 'medium' ? 'rgba(245, 158, 11, 0.5)' :
                                   'rgba(59, 130, 246, 0.5)',
                      background: finding.severity === 'critical' ? 'rgba(239, 68, 68, 0.05)' :
                                  finding.severity === 'high' ? 'rgba(249, 115, 22, 0.05)' :
                                  finding.severity === 'medium' ? 'rgba(245, 158, 11, 0.05)' :
                                  'rgba(59, 130, 246, 0.05)'
                    }}>
                      <div className="flex items-start justify-between mb-3">
                        <div className="flex-1">
                          <div className="flex items-center gap-2 mb-2">
                            <span className={`px-2 py-1 rounded text-xs font-bold uppercase ${
                              finding.severity === 'critical' ? 'bg-red-500 text-white' :
                              finding.severity === 'high' ? 'bg-orange-500 text-white' :
                              finding.severity === 'medium' ? 'bg-yellow-500 text-white' :
                              'bg-blue-500 text-white'
                            }`}>
                              {finding.severity}
                            </span>
                            <h4 className="font-bold text-white">{finding.title}</h4>
                          </div>
                          <p className="text-gray-300 text-sm mb-3">{finding.description}</p>
                          <div className="bg-slate-900/50 rounded-lg p-3">
                            <div className="text-xs font-semibold text-gray-400 mb-1">RECOMMENDED SOLUTION:</div>
                            <div className="text-sm text-gray-300">{finding.solution}</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              {/* Actions */}
              <div className="flex gap-3">
                <button
                  className="px-6 py-3 rounded-lg font-semibold text-white"
                  style={{ background: 'linear-gradient(135deg, #0047AB 0%, #DAA520 100())' }}
                >
                  Download PDF Report
                </button>
                <button className="px-6 py-3 rounded-lg font-semibold bg-slate-700 text-white hover:bg-slate-600">
                  Export JSON
                </button>
                <button className="px-6 py-3 rounded-lg font-semibold bg-slate-700 text-white hover:bg-slate-600">
                  Run New Scan
                </button>
              </div>
            </div>
          </div>
        ) : (
          /* Scans List View */
          <div className="grid gap-4">
            {scans.map((scan) => (
              <div
                key={scan.id}
                onClick={() => scan.status === 'completed' && setSelectedScan(scan)}
                className={`bg-slate-800/50 backdrop-blur-sm border rounded-xl p-6 transition-all ${
                  scan.status === 'completed' ? 'hover:border-blue-500/50 cursor-pointer' : ''
                }`}
                style={{ borderColor: 'rgba(71, 85, 105, 0.5)' }}
              >
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-4">
                    <div className="w-14 h-14 rounded-xl flex items-center justify-center text-2xl" style={{ background: 'rgba(0, 71, 171, 0.2)' }}>
                      🔍
                    </div>
                    <div>
                      <h3 className="text-lg font-bold text-white">{scan.assetName}</h3>
                      <div className="text-sm text-gray-400">{scan.assetUrl}</div>
                      <div className="text-xs text-gray-500 mt-1">
                        Started {scan.startedAt} • Duration: {scan.duration}
                      </div>
                    </div>
                  </div>

                  <div className="flex items-center gap-6">
                    {scan.status === 'completed' && (
                      <>
                        <div className="grid grid-cols-4 gap-3 text-center">
                          <div>
                            <div className="text-xl font-bold text-red-400">{scan.vulnerabilities.critical}</div>
                            <div className="text-xs text-gray-400">Critical</div>
                          </div>
                          <div>
                            <div className="text-xl font-bold text-orange-400">{scan.vulnerabilities.high}</div>
                            <div className="text-xs text-gray-400">High</div>
                          </div>
                          <div>
                            <div className="text-xl font-bold text-yellow-400">{scan.vulnerabilities.medium}</div>
                            <div className="text-xs text-gray-400">Medium</div>
                          </div>
                          <div>
                            <div className="text-xl font-bold text-blue-400">{scan.vulnerabilities.low}</div>
                            <div className="text-xs text-gray-400">Low</div>
                          </div>
                        </div>

                        <div className="text-center">
                          <div className="text-3xl font-bold mb-1" style={{
                            color: scan.score >= 90 ? '#10b981' : scan.score >= 70 ? '#f59e0b' : '#ef4444'
                          }}>
                            {scan.score}
                          </div>
                          <div className="text-xs text-gray-400">Score</div>
                        </div>
                      </>
                    )}

                    <div className={`px-4 py-2 rounded-lg text-sm font-medium ${
                      scan.status === 'completed' ? 'bg-green-500/20 text-green-400' :
                      scan.status === 'running' ? 'bg-blue-500/20 text-blue-400' :
                      'bg-red-500/20 text-red-400'
                    }`}>
                      {scan.status === 'completed' ? '✓ Completed' :
                       scan.status === 'running' ? '⟳ Running...' :
                       '✕ Failed'}
                    </div>
                  </div>
                </div>
              </div>
            ))}

            {scans.length === 0 && (
              <div className="text-center py-16">
                <div className="text-6xl mb-4">🔍</div>
                <h3 className="text-xl font-bold text-white mb-2">No Scans Yet</h3>
                <p className="text-gray-400 mb-6">Add assets to start security scanning</p>
                <button
                  onClick={() => router.push('/assets')}
                  className="px-8 py-4 rounded-xl font-bold text-white shadow-lg"
                  style={{ background: 'linear-gradient(135deg, #0047AB 0%, #DAA520 100%)' }}
                >
                  Go to Assets
                </button>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
