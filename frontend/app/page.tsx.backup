'use client';

import { useState } from 'react';
import { useRouter } from 'next/navigation';
import { MockAPIClient } from '@/lib/mock-api';

export default function Home() {
  const router = useRouter();
  const [loading, setLoading] = useState<boolean>(false);
  const [inputValue, setInputValue] = useState<string>('');
  const [error, setError] = useState<string>('');
  const [activeTab, setActiveTab] = useState<'photo' | 'video' | 'website' | 'company'>('photo');
  const [selectedFile, setSelectedFile] = useState<File | null>(null);

  const handleCheckWebsite = async () => {
    if (!inputValue.trim()) {
      setError('Please enter a URL');
      return;
    }

    setLoading(true);
    setError('');

    try {
      const result = await MockAPIClient.checkURL(inputValue);
      // Store result in sessionStorage
      sessionStorage.setItem('lastCheck', JSON.stringify(result));
      // Navigate to results
      router.push(`/check/${result.id}`);
    } catch (err) {
      setError('Check failed. Please try again.');
    } finally {
      setLoading(false);
    }
  };

  const handleCheckPhoto = async () => {
    setLoading(true);
    setError('');

    try {
      const result = await MockAPIClient.verifyPhoto('https://example.com/photo.jpg');
      sessionStorage.setItem('lastCheck', JSON.stringify(result));
      router.push(`/check/${result.id}`);
    } catch (err) {
      setError('Photo check failed. Please try again.');
    } finally {
      setLoading(false);
    }
  };

  const handleCheckVideo = async () => {
    setLoading(true);
    setError('');

    try {
      const result = await MockAPIClient.verifyVideo('https://example.com/video.mp4');
      sessionStorage.setItem('lastCheck', JSON.stringify(result));
      router.push(`/check/${result.id}`);
    } catch (err) {
      setError('Video check failed. Please try again.');
    } finally {
      setLoading(false);
    }
  };
  return (
    <main className="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-slate-100">
      {/* Navigation Bar */}
      <nav className="border-b border-blue-100 bg-white/80 backdrop-blur-md sticky top-0 z-50">
        <div className="container mx-auto px-4 py-4">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className="w-10 h-10 rounded-lg flex items-center justify-center" style={{ background: 'linear-gradient(135deg, #0047AB 0%, #DAA520 100%)' }}>
                <svg className="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <div className="font-bold text-lg" style={{ color: '#0047AB' }}>
                  AFRICA <span style={{ color: '#DAA520' }}>CYBER TRUST</span>
                </div>
                <div className="text-xs text-gray-500">INFRASTRUCTURE</div>
              </div>
            </div>
            <div className="hidden md:flex gap-6 items-center">
              <a href="/" className="text-gray-600 hover:text-blue-700 transition">Home</a>
              <a href="/about" className="text-gray-600 hover:text-blue-700 transition">About</a>
              <a href="/pricing" className="text-gray-600 hover:text-blue-700 transition">Pricing</a>
              <a href="/business" className="text-gray-600 hover:text-blue-700 transition">For Business</a>
              <a href="/contact" className="text-gray-600 hover:text-blue-700 transition">Contact</a>
              <a href="/auth/login" className="text-gray-600 hover:text-blue-700 transition">Login</a>
              <a
                href="/auth/signup"
                className="px-4 py-2 rounded-lg font-semibold text-white shadow-md hover:shadow-lg transition-all"
                style={{ background: 'linear-gradient(135deg, #0047AB 0%, #1E90FF 100%)' }}
              >
                Sign Up
              </a>
            </div>
          </div>
        </div>
      </nav>

      {/* Hero Section */}
      <div className="container mx-auto px-4 py-20">
        <div className="text-center mb-16 max-w-4xl mx-auto">
          <div className="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-100 text-blue-700 text-sm font-medium mb-6">
            <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" />
            </svg>
            AI-Powered Security for Africa
          </div>

          <h1 className="text-6xl font-bold mb-8 leading-tight">
            <span style={{ color: '#0047AB' }}>Africa Cyber Trust</span>
            <br />
            <span style={{ color: '#DAA520' }}>Infrastructure</span>
          </h1>

          <div className="flex flex-wrap gap-4 justify-center">
            <a href="#check" className="px-8 py-4 rounded-lg font-semibold text-white shadow-xl hover:shadow-2xl transition-all transform hover:scale-105" style={{ background: 'linear-gradient(135deg, #0047AB 0%, #1E90FF 100%)' }}>
              Start Free Check
            </a>
            <a href="/business" className="px-8 py-4 rounded-lg font-semibold border-2 hover:bg-blue-50 transition-all" style={{ borderColor: '#0047AB', color: '#0047AB' }}>
              For Businesses
            </a>
          </div>
        </div>

        {/* Quick Check Section */}
        <div className="max-w-4xl mx-auto" id="check">
          <div className="bg-white rounded-3xl shadow-2xl p-8 md:p-12 mb-16 border-t-4" style={{ borderTopColor: '#DAA520' }}>
            <div className="flex items-center gap-3 mb-6">
              <div className="w-12 h-12 rounded-xl flex items-center justify-center" style={{ background: 'linear-gradient(135deg, #0047AB 0%, #DAA520 100%)' }}>
                <svg className="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
              <h2 className="text-3xl font-bold" style={{ color: '#0047AB' }}>
                Security & Authenticity Checker
              </h2>
            </div>

            <p className="text-gray-600 mb-8 text-lg">
              Verify websites, detect AI-generated photos & videos, and check company legitimacy with our AI-powered platform.
            </p>

            <div className="flex flex-col gap-4">
              {/* URL Input */}
              <div>
                <label className="block text-sm font-semibold mb-2 text-gray-700">Website URL or Company Name</label>
                <input
                  type="text"
                  value={inputValue}
                  onChange={(e) => setInputValue(e.target.value)}
                  onKeyPress={(e) => e.key === 'Enter' && handleCheckWebsite()}
                  placeholder="Enter URL (https://example.com) or company name..."
                  className="w-full px-6 py-4 text-lg border-2 rounded-xl focus:outline-none transition-all shadow-sm"
                  style={{ borderColor: error ? '#DC2626' : '#E5E7EB' }}
                  onFocus={(e) => { e.currentTarget.style.borderColor = '#0047AB'; setError(''); }}
                  onBlur={(e) => e.currentTarget.style.borderColor = error ? '#DC2626' : '#E5E7EB'}
                  disabled={loading}
                />
              </div>

              {/* OR Divider */}
              <div className="flex items-center gap-4 my-2">
                <div className="flex-1 border-t border-gray-300"></div>
                <span className="text-gray-500 font-semibold">OR</span>
                <div className="flex-1 border-t border-gray-300"></div>
              </div>

              {/* File Upload */}
              <div>
                <label className="block text-sm font-semibold mb-2 text-gray-700">Upload Photo or Video</label>
                <label className="flex items-center justify-center w-full px-6 py-8 border-2 border-dashed rounded-xl cursor-pointer hover:border-blue-500 transition-all bg-gray-50 hover:bg-blue-50">
                  <div className="text-center">
                    <svg className="w-12 h-12 mx-auto mb-3" style={{ color: '#0047AB' }} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                    </svg>
                    <p className="text-sm font-semibold text-gray-700">Click to upload or drag & drop</p>
                    <p className="text-xs text-gray-500 mt-1">PNG, JPG, MP4, WebM (max 10MB for photos, 100MB for videos)</p>
                  </div>
                  <input
                    type="file"
                    accept="image/*,video/*"
                    onChange={(e) => {
                      const file = e.target.files?.[0];
                      if (file) {
                        if (file.type.startsWith('image/')) {
                          handleCheckPhoto();
                        } else if (file.type.startsWith('video/')) {
                          handleCheckVideo();
                        }
                      }
                    }}
                    className="hidden"
                    disabled={loading}
                  />
                </label>
              </div>

              {error && <p className="text-red-600 text-sm -mt-2">{error}</p>}

              {loading && (
                <div className="flex items-center justify-center gap-3 py-4">
                  <div className="w-6 h-6 border-3 border-t-blue-600 border-blue-200 rounded-full animate-spin"></div>
                  <span className="text-gray-600">Analyzing...</span>
                </div>
              )}

              <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                <button
                  onClick={handleCheckPhoto}
                  disabled={loading}
                  className="px-6 py-3 rounded-xl font-semibold text-white shadow-lg hover:shadow-xl transition-all border-2 border-transparent disabled:opacity-50 disabled:cursor-not-allowed"
                  style={{ background: 'linear-gradient(135deg, #0047AB 0%, #1E90FF 100%)' }}
                >
                  <span className="flex items-center justify-center gap-2">
                    <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    Check Photo
                  </span>
                </button>
                <button
                  onClick={handleCheckVideo}
                  disabled={loading}
                  className="px-6 py-3 rounded-xl font-semibold text-white shadow-lg hover:shadow-xl transition-all border-2 border-transparent disabled:opacity-50 disabled:cursor-not-allowed"
                  style={{ background: 'linear-gradient(135deg, #DAA520 0%, #FFD700 100())' }}
                >
                  <span className="flex items-center justify-center gap-2">
                    <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                    Check Video
                  </span>
                </button>
                <button
                  onClick={handleCheckWebsite}
                  disabled={loading}
                  className="px-6 py-3 rounded-xl font-semibold text-white shadow-lg hover:shadow-xl transition-all border-2 border-transparent disabled:opacity-50 disabled:cursor-not-allowed"
                  style={{ background: 'linear-gradient(135deg, #1E90FF 0%, #0047AB 100%)' }}
                >
                  <span className="flex items-center justify-center gap-2">
                    <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                    </svg>
                    Check Website
                  </span>
                </button>
                <button
                  onClick={() => {
                    if (!inputValue) {
                      setError('Please enter a company name');
                      return;
                    }
                    setLoading(true);
                    setTimeout(() => {
                      setLoading(false);
                      alert('Company background check feature coming soon! This will check: company registration, legitimacy, online reputation, and trust score.');
                    }, 2000);
                  }}
                  disabled={loading}
                  className="px-6 py-3 rounded-xl font-semibold text-white shadow-lg hover:shadow-xl transition-all border-2 border-transparent disabled:opacity-50 disabled:cursor-not-allowed"
                  style={{ background: 'linear-gradient(135deg, #10B981 0%, #059669 100%)' }}
                >
                  <span className="flex items-center justify-center gap-2">
                    <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                    Check Company
                  </span>
                </button>
              </div>
            </div>

            <div className="flex items-center gap-4 mt-6 text-sm text-gray-500">
              <div className="flex items-center gap-2">
                <svg className="w-5 h-5" style={{ color: '#0047AB' }} fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                </svg>
                Free passive check
              </div>
              <div className="flex items-center gap-2">
                <svg className="w-5 h-5" style={{ color: '#0047AB' }} fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                </svg>
                No registration required
              </div>
              <div className="flex items-center gap-2">
                <svg className="w-5 h-5" style={{ color: '#0047AB' }} fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                </svg>
                AI-powered insights
              </div>
            </div>
          </div>

          {/* Services Section Header */}
          <div className="text-center mb-12" id="features">
            <h2 className="text-4xl font-bold mb-4" style={{ color: '#0047AB' }}>
              Our <span style={{ color: '#DAA520' }}>Security Services</span>
            </h2>
            <p className="text-gray-600 text-lg max-w-3xl mx-auto">
              Comprehensive AI-powered security solutions to protect your digital presence and verify authenticity
            </p>
          </div>

          {/* Feature Cards - 5 Cards Grid */}
          <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            {/* Card 1 - AI Photo Verification */}
            <div className="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all border-t-4 group" style={{ borderTopColor: '#0047AB' }}>
              <div className="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform" style={{ background: 'linear-gradient(135deg, #0047AB 15%, #1E90FF 85%)' }}>
                <svg className="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 className="text-2xl font-bold mb-3" style={{ color: '#0047AB' }}>AI Photo Detection</h3>
              <p className="text-gray-600 leading-relaxed">
                Verify if images are AI-generated or authentic. Detect deepfakes, manipulated photos, and synthetic content with advanced AI analysis
              </p>
              <div className="mt-4 flex items-center gap-2 text-sm" style={{ color: '#0047AB' }}>
                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                </svg>
                Deepfake Detection
              </div>
            </div>

            {/* Card 2 - AI Video Verification */}
            <div className="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all border-t-4 group" style={{ borderTopColor: '#DAA520' }}>
              <div className="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform" style={{ background: 'linear-gradient(135deg, #DAA520 15%, #FFD700 85%)' }}>
                <svg className="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 className="text-2xl font-bold mb-3" style={{ color: '#DAA520' }}>AI Video Detection</h3>
              <p className="text-gray-600 leading-relaxed">
                Analyze videos for AI generation, deepfake manipulation, and authenticity. Frame-by-frame analysis to detect synthetic content
              </p>
              <div className="mt-4 flex items-center gap-2 text-sm" style={{ color: '#DAA520' }}>
                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                </svg>
                Real vs AI-Generated
              </div>
            </div>

            {/* Card 3 - Website Trust Scoring */}
            <div className="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all border-t-4 group" style={{ borderTopColor: '#1E90FF' }}>
              <div className="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform" style={{ background: 'linear-gradient(135deg, #1E90FF 15%, #0047AB 85%)' }}>
                <svg className="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 className="text-2xl font-bold mb-3" style={{ color: '#1E90FF' }}>Trust Scoring</h3>
              <p className="text-gray-600 leading-relaxed">
                AI-powered website analysis with clear risk levels and detailed explanations for every security check
              </p>
              <div className="mt-4 flex items-center gap-2 text-sm" style={{ color: '#1E90FF' }}>
                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                </svg>
                Instant Risk Analysis
              </div>
            </div>

            {/* Card 4 - Background Checks */}
            <div className="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all border-t-4 group" style={{ borderTopColor: '#0047AB' }}>
              <div className="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform" style={{ background: 'linear-gradient(135deg, #0047AB 15%, #1E90FF 85%)' }}>
                <svg className="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
              <h3 className="text-2xl font-bold mb-3" style={{ color: '#0047AB' }}>Background Checks</h3>
              <p className="text-gray-600 leading-relaxed">
                Comprehensive passive checks on domains, SSL certificates, blacklists, and security headers
              </p>
              <div className="mt-4 flex items-center gap-2 text-sm" style={{ color: '#0047AB' }}>
                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                </svg>
                Malware Detection
              </div>
            </div>

            {/* Card 5 - Enterprise Monitoring */}
            <div className="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all border-t-4 group" style={{ borderTopColor: '#DAA520' }}>
              <div className="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform" style={{ background: 'linear-gradient(135deg, #DAA520 15%, #FFD700 85%)' }}>
                <svg className="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>
              <h3 className="text-2xl font-bold mb-3" style={{ color: '#DAA520' }}>Enterprise Monitoring</h3>
              <p className="text-gray-600 leading-relaxed">
                Continuous monitoring, real-time alerts, and detailed security reports for verified business assets
              </p>
              <div className="mt-4 flex items-center gap-2 text-sm" style={{ color: '#DAA520' }}>
                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                </svg>
                24/7 Security Alerts
              </div>
            </div>
