# Database
DATABASE_URL=postgresql://acti_user:acti_dev_password_change_in_production@localhost:5432/africa_cyber_trust

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development
DEBUG=True

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# AI Services
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# S3-compatible storage (for reports, evidence)
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=acti-reports
S3_REGION=us-east-1

# Email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@africacybertrust.com

# SMS alerts (Twilio or Africa Gateway)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp alerts
WHATSAPP_API_KEY=your-whatsapp-api-key

# Rate limiting
RATE_LIMIT_PUBLIC_CHECKS_PER_HOUR=10
RATE_LIMIT_SCANS_PER_DAY=5

# Scanning safety controls
BLOCK_GOVERNMENT_DOMAINS=True
BLOCK_MILITARY_DOMAINS=True
BLOCK_FINANCIAL_DOMAINS=True
REQUIRE_MANUAL_APPROVAL_FOR_CRITICAL_INFRA=True

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
